{
  "name": "life-system-kanban",
  "version": "1.0.0",
  "description": "A modern Kanban board application with drag-and-drop functionality",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
